{
  "name": "nxjt",
  "version": "0.0.1",
  "private": true,
  "description": "Quickly navigate to npmx common webpages.",
  "keywords": [
    "npmx",
    "nxjt",
    "npmxpmx-jump-tp",
    "chrome",
    "firefox",
    "alfred"
  ],
  "homepage": "https://nxjt.trueberryless.org",
  "bugs": {
    "url": "https://github.com/trueberryless-org/nxjt/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/trueberryless-org/nxjt.git"
  },
  "license": "MIT",
  "author": "trueberryless <trueberryless@gmail.com> (https://trueberryless.org)",
  "type": "module",
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "dev": "astro dev",
    "lint": "prettier -c --cache . && eslint . --cache --max-warnings=0 && tsc --noEmit && astro check",
    "prepare": "husky",
    "preview": "astro preview",
    "start": "astro dev",
    "test": "vitest"
  },
  "lint-staged": {
    "*": [
      "prettier -w -u --cache",
      "eslint --cache --no-warn-ignored --max-warnings=0"
    ]
  },
  "dependencies": {
    "@astrojs/check": "0.9.6",
    "@astrojs/netlify": "^7.0.8",
    "@astrojs/vercel": "10.0.6",
    "@unocss/reset": "66.6.8",
    "astro": "6.1.10"
  },
  "devDependencies": {
    "@hideoo/eslint-config": "4.1.1",
    "@hideoo/prettier-config": "2.0.0",
    "@hideoo/tsconfig": "2.0.1",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/node": "24.12.2",
    "eslint": "10.2.1",
    "husky": "9.0.11",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "6.0.3",
    "vercel": "52.2.0",
    "vitest": "4.1.5"
  },
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=18"
  }
}
